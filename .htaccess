RewriteEngine On

# Redirect HTTP to HTTPS (uncomment if SSL is configured)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block access to sensitive directories
RewriteRule ^config/ - [F,L]
RewriteRule ^includes/ - [F,L]
RewriteRule ^sql/ - [F,L]

# Block access to .bak files
<FilesMatch "\.(bak|sql|log|ini)$">
    Require all denied
</FilesMatch>

# PHP settings for Apache mod_php only (ignored on LiteSpeed/CGI)
# For Hostinger/LiteSpeed, use .user.ini instead
<IfModule mod_php7.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 25M
    php_value max_execution_time 120
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
</IfModule>
